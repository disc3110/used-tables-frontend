NODE_ENV=development
PORT=4000
API_PREFIX=api
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/used_billiard_store?schema=public
JWT_SECRET=replace-with-a-long-random-secret-at-least-24-characters
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Product uploads are saved under this folder plus /products.
CLOUDINARY_FOLDER=used-billiard-store
ADMIN_SEED_NAME=Admin User
ADMIN_SEED_EMAIL=admin@usedbilliardstore.ca
ADMIN_SEED_PASSWORD=admin12345
USER_SEED_NAME=Store User
USER_SEED_EMAIL=user@usedbilliardstore.ca
USER_SEED_PASSWORD=user12345
